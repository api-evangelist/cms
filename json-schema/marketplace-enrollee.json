{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Enrollee",
  "description": "Schema for Enrollee from CMS Marketplace API",
  "properties": {
    "enrollmentGroupID": {
      "description": "Enrollment group id",
      "type": "string",
      "pattern": "^[a-f0-9-]+$"
    },
    "tobaccoDate": {
      "description": "Date of last tobacco use (YYYY-MM-DD)",
      "type": "string"
    }
  },
  "type": "object",
  "required": [
    "enrollmentGroupID"
  ]
}