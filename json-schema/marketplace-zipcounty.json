{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZIPCounty",
  "description": "Schema for ZIPCounty from CMS Marketplace API",
  "properties": {
    "fips": {
      "format": "^[0-9]{5}$",
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "state": {
      "format": "^[A-Z]{2}$",
      "type": "string"
    },
    "zipcode": {
      "format": "^[0-9]{5}$",
      "type": "string"
    }
  },
  "type": "object"
}